# ─────────────────────────────────────────────
#  Zion's Men's PG  –  Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://127.0.0.1:27017/zions_pg
# Server port
PORT=5000

# Environment
NODE_ENV=development

# Optional: a secret for future JWT auth
JWT_SECRET=your_super_secret_key_here
